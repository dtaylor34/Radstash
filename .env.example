# ═══════════════════════════════════════════════════════════════
# Radstash — Environment Variables
# Copy this to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# Supabase (create at supabase.com)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Firebase Auth (create at console.firebase.google.com)
EXPO_PUBLIC_FIREBASE_API_KEY=your-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
EXPO_PUBLIC_FIREBASE_APP_ID=your-app-id

# Comic Vine — cover images (free key at comicvine.gamespot.com/api)
EXPO_PUBLIC_COMICVINE_API_KEY=your-comic-vine-api-key

# AI Scanning — client-side for dev (get key at console.anthropic.com)
EXPO_PUBLIC_ANTHROPIC_API_KEY=your-anthropic-key

# AI Scanning — server-side for production (set in Supabase dashboard, not here)
# ANTHROPIC_API_KEY=your-anthropic-key

# Production scan endpoint (uncomment when Edge Function is deployed)
# EXPO_PUBLIC_SCAN_ENDPOINT=https://your-project.supabase.co/functions/v1/identify-item

# Stripe — marketplace payments
# EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-key
# STRIPE_SECRET_KEY=sk_test_your-key
